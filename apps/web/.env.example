# apps/web environment — copy to apps/web/.env and fill in real values.
# NEVER commit a filled-in .env (it is gitignored). This file holds NAMES ONLY.
# Vite only exposes vars prefixed VITE_ to the browser — anon key ONLY, never the
# service-role key.

# Supabase project (same project the API uses; staging and prod each get their own).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base URL of the Pacer API (apps/api). Defaults to http://localhost:8787 if unset.
VITE_API_URL=
