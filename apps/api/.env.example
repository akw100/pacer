# apps/api environment — copy to apps/api/.env and fill in real values.
# NEVER commit a filled-in .env (it is gitignored). This file holds NAMES ONLY.

# Supabase project (staging and production each get their OWN project).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only needed if you verify JWTs locally against the secret instead of
# via auth.getUser(). Safe to leave blank for the default getUser() flow.
SUPABASE_JWT_SECRET=

# HTTP port (defaults to 8787 if unset).
PORT=8787

# Origin of the web app — used for CORS. Defaults to http://localhost:5173.
WEB_ORIGIN=

# IANA timezone the Telegram bot stamps run dates in (e.g. Asia/Jerusalem).
# Defaults to UTC; set it to the group's zone so late-night logs land on the
# right local day (the web app buckets activity by the user's local date).
APP_TIMEZONE=

# Telegram bot (grammY). Bot is disabled if TELEGRAM_BOT_TOKEN is unset.
TELEGRAM_BOT_TOKEN=
# Shared secret echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token header (webhook mode).
TELEGRAM_WEBHOOK_SECRET=
# 'polling' (default, local dev) or 'webhook' (production).
TELEGRAM_MODE=
# Public HTTPS URL Telegram should POST updates to (webhook mode), e.g. https://api.example.com/webhook
TELEGRAM_WEBHOOK_URL=

# Python frames worker (services/frames) — used by the video-routines slice.
FRAMES_SERVICE_URL=
# Shared secret guarding the worker ↔ api internal callback (must match the worker).
INTERNAL_TOKEN=

# OpenAI standing key (server-side only). Powers the Telegram bot's text+vision
# run parsing, mints Realtime ephemeral tokens for the in-app voice agent, and
# backs Pacer Coach (Responses API). Never exposed to the browser.
OPENAI_KEY=
# Optional: override the Realtime model bound to voice sessions (default gpt-realtime).
OPENAI_REALTIME_MODEL=
# Optional: override the chat model used by Pacer Coach (default gpt-4o-mini).
OPENAI_CHAT_MODEL=
