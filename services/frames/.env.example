# services/frames environment — copy to services/frames/.env and fill in real
# values. NEVER commit a filled-in .env (it is gitignored). NAMES ONLY here.

# Shared secret guarding the api ↔ worker calls (must match apps/api INTERNAL_TOKEN).
INTERNAL_TOKEN=
# Base URL of the Hono api the worker posts results back to (e.g. http://localhost:8787).
API_BASE_URL=

# Supabase — service role is used ONLY for Storage uploads to the video-frames bucket.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — gpt-4o-mini vision picks the clearest frame per section.
OPENAI_API_KEY=

# Optional: yt-dlp cookies (Netscape file CONTENTS, not a path) to get past
# "sign in to confirm" / age gates on datacenter IPs.
YTDLP_COOKIES=
# Optional: outbound proxy for yt-dlp if Railway IPs get blocked.
YTDLP_PROXY=

# Tuning (all optional; defaults shown).
MAX_VIDEO_MINUTES=45
MAX_CONCURRENT_JOBS=2
MAX_SECTIONS=24
FALLBACK_SECTIONS=8
FRAMES_PER_SECTION=5
